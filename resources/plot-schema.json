{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://studio.kdb.org/plot/schema#",
  "title": "Plot configuration schema",
  "type": "object",
  "properties": {
    "title": {
      "$ref": "#/definitions/Label"
    },
    "id": {
      "type": "string"
    },
    "legend": {
      "$ref": "#/definitions/Legend"
    },
    "type": {
      "$ref": "#/definitions/ChartType"
    },
    "domainAxis": {
      "$ref": "#/definitions/DomainAxis"
    },
    "rangeAxis": {
      "$ref": "#/definitions/RangeAxis"
    },
    "grid": {
      "$ref": "#/definitions/Grid"
    },
    "backgroundColor": {
      "type": "string",
      "format": "color"
    },
    "plotBackgroundColor": {
      "type": "string",
      "format": "color"
    },
    "series": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Series"
      }
    },
    "padding": {
      "$ref": "#/definitions/RectangleInsets"
    },
    "size": {
      "$ref": "#/definitions/Size"
    }
  },
  "required": ["id"],
  "definitions": {
    "Series": {
      "type": "object",
      "properties": {
        "lineWidth": {
          "type": "number"
        },
        "color": {
          "type": "string",
          "format": "color"
        },
        "fillColor": {
          "type": "string",
          "format": "color"
        },
        "outlineColor": {
          "type": "string",
          "format": "color"
        },
        "lineType" : {
          "$ref": "#/definitions/LineType"
        },
        "marker" : {
          "$ref": "#/definitions/Marker"
        },
        "visibleInLegend": {
          "type": "boolean"
        },
        "show": {
          "type": "boolean"
        }
      }
    },
    "ChartType": {
      "type": "string",
      "enum": [
        "LINE",
        "STAIRCASE",
        "SCATTER"
      ]
    },
    "LineType": {
      "type": "string",
      "enum": [
        "SOLID",
        "DASHED",
        "DASH_DOT",
        "DOT_DOT"
      ]
    },
    "Label": {
      "type": "object",
      "properties": {
        "show": {
          "type": "boolean"
        },
        "text": {
          "type": "string"
        },
        "font": {
          "$ref": "#/definitions/Font"
        },
        "color": {
          "type": "string",
          "format": "color"
        }
      },
      "required": [
        "show"
      ]
    },
    "DomainAxis": {
      "type": "object",
      "properties": {
        "label": {
          "$ref": "#/definitions/Label"
        },
        "ticks": {
          "$ref": "#/definitions/Tick"
        },
        "axisLineColor": {
          "type": "string",
          "format": "color"
        },
        "tickMarkColor": {
          "type": "string",
          "format": "color"
        }
      }
    },
    "RangeAxis": {
      "allOf": [
        {
          "$ref": "#/definitions/DomainAxis"
        },
        {
          "properties": {
            "range": {
              "$ref": "#/definitions/Range"
            },
            "tickUnit": {
              "$ref": "#/definitions/TickUnit"
            }
          }
        }
      ]
    },
    "Range": {
      "type": "object",
      "properties": {
        "autoAdjust": {
          "type": "boolean"
        },
        "minimumRangeValue": {
          "type": "number"
        },
        "maximumRangeValue": {
          "type": "number"
        }
      },
      "required": [
        "autoAdjust"
      ]
    },
    "TickUnit": {
      "type": "object",
      "properties": {
        "autoSelection": {
          "type": "boolean"
        },
        "tickUnitValue": {
          "type": "number"
        }
      }
    },
    "Tick": {
      "type": "object",
      "properties": {
        "showTickLabels": {
          "type": "boolean"
        },
        "showTickMarks": {
          "type": "boolean"
        },
        "tickLabelFont": {
          "$ref": "#/definitions/Font"
        },
        "tickLabelColor": {
          "type": "string",
          "format": "color"
        }
      },
      "required": [
        "showTickLabels",
        "showTickMarks"
      ]
    },
    "Font": {
      "type": "object",
      "properties": {
        "size": {
          "type": "integer"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PLAIN",
              "BOLD",
              "ITALIC"
            ]
          }
        },
        "font": {
          "type": "string"
        }
      },
      "required": [
        "size",
        "attributes",
        "font"
      ]
    },
    "Grid": {
      "type": "object",
      "properties": {
        "horizontal": {
          "type": "boolean"
        },
        "horizontalLineWidth": {
          "type": "number"
        },
        "horizontalLineColor": {
          "type": "string",
          "format": "color"
        },
        "horizontalLineType" : {
          "$ref": "#/definitions/LineType"
        },
        "vertical": {
          "type": "boolean"
        },
        "verticalLineWidth": {
          "type": "number"
        },
        "verticalLineColor": {
          "type": "string",
          "format": "color"
        },
        "verticalLineType" : {
          "$ref": "#/definitions/LineType"
        }
      }
    },
    "Position": {
      "type": "string",
      "enum": [
        "TOP",
        "BOTTOM",
        "LEFT",
        "RIGHT"
      ]
    },
    "RectangleInsets": {
      "type": "object",
      "properties": {
        "top": {
          "type": "number"
        },
        "left": {
          "type": "number"
        },
        "bottom": {
          "type": "number"
        },
        "right": {
          "type": "number"
        }
      },
      "required": [
        "top",
        "left",
        "bottom",
        "right"
      ]
    },
    "Legend": {
      "type": "object",
      "properties": {
        "show": {
          "type": "boolean"
        },
        "margin": {
          "$ref": "#/definitions/RectangleInsets"
        },
        "position": {
          "$ref": "#/definitions/Position"
        },
        "backgroundColor": {
          "type": "string",
          "format": "color"
        }
      },
      "required": [
        "show"
      ]
    },
    "Size": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "Marker": {
      "type": "object",
      "properties": {
        "type": {
          "$ref": "#/definitions/MarkerType"
        },
        "size": {
          "type": "integer"
        }
      },
      "required": ["type", "size"]
    },
    "MarkerType": {
      "type": "string",
      "enum": [
        "SQUARE",
        "CIRCLE",
        "ELLIPSE",
        "TRIANGLE_UP_POINTING",
        "TRIANGLE_DOWN_POINTING",
        "TRIANGLE_RIGHT_POINTING",
        "TRIANGLE_LEFT_POINTING",
        "DIAMOND",
        "RECTANGLE_HORIZONTAL",
        "RECTANGLE_VERTICAL"
      ]
    }
  }
}